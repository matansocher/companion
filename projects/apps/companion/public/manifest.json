{
  "manifest_version": 3,
  "name": "Companion",
  "version": "1.0.0",
  "description": "Your companion side panel extension",
  "permissions": ["sidePanel", "activeTab", "scripting", "tabs", "storage", "alarms", "webNavigation", "idle", "identity"],
  "host_permissions": ["<all_urls>"],
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "sandbox": {
    "pages": [
      "sandbox.html"
    ]
  },
  "content_security_policy": {
    "sandbox": "sandbox allow-scripts allow-forms allow-popups allow-modals; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://maps.googleapis.com; child-src 'self';"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open Companion"
  }
}
